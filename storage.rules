rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // โฟลเดอร์รูปแจ้งซ่อม: อนุญาตให้ดูรูปได้ และให้เฉพาะผู้เช่าที่เป็นคนอัปโหลด มีสิทธิ์เขียนไฟล์ลงโฟลเดอร์ตัวเอง
    match /repairs/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // สำหรับโฟลเดอร์อื่นๆ
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
